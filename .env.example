# Ngao environment configuration
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# Never commit your real .env file. It contains secrets.

# Required. GitHub token used by the bot to read pull requests, post comments,
# create/read labels, and update labels on pull requests.
#
# Fine-grained personal access token permissions:
# - Repository access: only the repositories where this webhook is installed
# - Pull requests: Read-only
# - Issues: Read and write
# - Metadata: Read-only (included automatically)
#
# Classic personal access token:
# - repo
GITHUB_TOKEN=ghp_your_github_token_here

# Required. Shared secret configured in GitHub webhook settings.
# Generate a random value, put the same value here and in the webhook Secret
# field, and keep it private.
WEBHOOK_SECRET=replace_with_a_long_random_secret

# Optional. Number of leading zeroes required in the SHA-256 proof-of-work hash.
# Default: 4. Higher values cost contributors more CPU time.
POW_DIFFICULTY=4
